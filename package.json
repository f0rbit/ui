{
	"name": "@f0rbit/ui",
	"version": "0.1.9",
	"description": "A minimal, composable UI component library for SolidJS",
	"keywords": [
		"components",
		"design-system",
		"solid",
		"solidjs",
		"ui"
	],
	"license": "MIT",
	"author": "f0rbit",
	"repository": {
		"type": "git",
		"url": "https://github.com/f0rbit/ui.git"
	},
	"files": [
		"dist",
		"src"
	],
	"type": "module",
	"main": "./dist/server.js",
	"module": "./dist/server.js",
	"browser": {
		"./dist/server.js": "./dist/index.js"
	},
	"types": "./dist/index.d.ts",
	"typesVersions": {},
	"exports": {
		".": {
			"worker": {
				"solid": "./dist/server.jsx",
				"import": {
					"types": "./dist/index.d.ts",
					"default": "./dist/server.js"
				}
			},
			"browser": {
				"solid": "./dist/index.jsx",
				"import": {
					"types": "./dist/index.d.ts",
					"default": "./dist/index.js"
				}
			},
			"deno": {
				"solid": "./dist/server.jsx",
				"import": {
					"types": "./dist/index.d.ts",
					"default": "./dist/server.js"
				}
			},
			"node": {
				"solid": "./dist/server.jsx",
				"import": {
					"types": "./dist/index.d.ts",
					"default": "./dist/server.js"
				}
			},
			"solid": "./dist/index.jsx",
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./styles": "./dist/styles.css",
		"./styles/tokens": "./dist/tokens.css",
		"./styles/reset": "./dist/reset.css",
		"./styles/utilities": "./dist/utilities.css",
		"./styles/components": "./dist/components.css",
		"./styles/starlight": "./dist/starlight.css"
	},
	"scripts": {
		"build": "tsup && npm run build:css",
		"build:css": "node scripts/build-css.js",
		"build:llm": "node scripts/generate-llm-docs.js",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build",
		"docs": "bun run build && bun run build:llm && cd docs && bun run dev",
		"docs:dev": "cd docs && bun run dev",
		"docs:build": "bun run build:llm && cd docs && bun run build",
		"lint": "oxlint . && eslint .",
		"lint:fix": "oxlint --fix . && eslint --fix .",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check ."
	},
	"devDependencies": {
		"@f0rbit/lint": "0.1.3",
		"@types/bun": "^1.3.14",
		"esbuild-plugin-solid": "^0.6.0",
		"solid-js": "^1.9.3",
		"tsup": "^8.3.5",
		"tsup-preset-solid": "^2.2.0",
		"typescript": "^5.7.2"
	},
	"peerDependencies": {
		"solid-js": "^1.8.0"
	}
}
